{
  "name": "adeeb_hono",
  "version": "0.1.0",
  "description": "Adeeb's Backend iteration in JS & TS, using Hono",
  "type": "module",
  "keywords": [
    "JavaScript",
    "TypeScript",
    "Postgres",
    "ValKey",
    "Hono"
  ],
  "author": "M-Shrief",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.3.0",
      "onFail": "download"
    }
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@hono/structured-logger": "^0.1.0",
    "@scalar/hono-api-reference": "^0.11.4",
    "@valibot/to-json-schema": "^1.7.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.26",
    "hono-openapi": "^1.3.0",
    "hono-rate-limiter": "^0.5.3",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.4",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  }
}